# Copy to .env.local and fill in. Never commit real secrets.
# Production: set the same keys in Vercel → Project → Settings → Environment Variables.

# Neon Postgres: use the POOLED connection string from Neon → Connect.
# The API uses TCP (postgres.js) with prepare:false for PgBouncer — not Neon’s HTTP driver.
# Hostname should contain "pooler" (e.g. ...-pooler....neon.tech). Unpooled URLs cause more "fetch failed" on Vercel.
# POSTGRES_URL=postgresql://...pooler...neon.tech/...
# If Vercel sets POSTGRES_URL to a direct (non-pooler) host but DATABASE_URL is pooled, api/lib/db.js prefers DATABASE_URL.
# Optional: force the pooled string regardless of Vercel’s variable names:
# NEON_POOL_URL=postgresql://...pooler...neon.tech/...
#
# Vercel + Neon: sometimes DATABASE_URL and POSTGRES_URL are empty in the pulled file while DATABASE_URL_UNPOOLED is set.
# For production, set at least one non-empty pooled URL in Vercel → Settings → Environment Variables (Production):
#   DATABASE_URL = pooled string from Neon Dashboard → Connect → "Connection pooling" / PgBouncer
# or POSTGRES_URL to the same pooled string so runtime and `vercel env pull` match migrations.
# TCP postgres.js uses connect_timeout (POSTGRES_CONNECT_TIMEOUT_SEC, default 45) — not Neon HTTP fetch.

RESEND_API_KEY=re_your_key_here
# Must match a domain verified in Resend (Dashboard → Domains). Until then, use onboarding@resend.dev for tests only.
NEWSLETTER_FROM_EMAIL=hello@your-verified-domain.com
# Optional: cap newsletter batch size (default 150, max 500)
# NEWSLETTER_MAX_SENDS=150

# Comma-separated emails that may use admin-only APIs (e.g. POST /api/events) when users.is_admin is false.
# Signing in with an address is NOT enough by itself: either set is_admin below, OR add that exact email here, OR set ADMIN_GRANT_USER_IDS.
# Prefer fixing the DB: UPDATE users SET is_admin = true WHERE LOWER(email) = 'owner@example.com';
# Sign in with Apple often uses a different users row than email/password; if that row has is_admin false, either set
# is_admin in Neon for that row, or list the Apple-visible email here.
# ADMIN_GRANT_EMAILS=owner@example.com
# Optional: comma-separated public.users UUIDs (same format as Neon id) when email-based grant is not enough
# (e.g. empty email on row, or Apple row differs from the email you listed).
# ADMIN_GRANT_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional IANA timezone for legacy `events.date` / `events.time` text when inserting (default America/New_York).
# EVENTS_DISPLAY_TZ=America/New_York

# --- Vercel Cron: GET /api/cron/poll-usps-tracking (see vercel.json)
# Without these, every call returns 401 (or you can use either secret for manual curl).
# Vercel: Project → Settings → Environment Variables → add CRON_SECRET for Production (16+ random chars).
# Vercel automatically sends Authorization: Bearer <CRON_SECRET> on scheduled cron invocations.
# CRON_SECRET=
# Optional second shared secret for manual runs (Bearer must match this or CRON_SECRET).
# PARCEL_TRACKING_POLL_SECRET=
# USPS Tracking API (if missing, the cron still returns 200 with enabled:false and skips API calls).
# USPS_CLIENT_ID=
# USPS_CLIENT_SECRET=
# USPS_API_BASE=https://apis.usps.com
