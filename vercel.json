{
  "version": 2,
  "buildCommand": "npm run vercel:sync",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "website/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/stripe/webhook", "destination": "/api/stripe-webhook" },
    { "source": "/api", "destination": "/api" },
    { "source": "/privacy", "destination": "/website/privacy.html" },
    { "source": "/terms", "destination": "/website/terms.html" },
    { "source": "/", "destination": "/website/index.html" },
    { "source": "/:path*", "destination": "/website/:path*" }
  ]
}
