{
  "name": "guilty-pleasure-treats",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.0",
  "scripts": {
    "vercel:sync": "bash scripts/sync-api-for-vercel.sh",
    "deploy": "npm run vercel:sync && vercel --prod",
    "neon:context": "neonctl set-context",
    "neon:connect": "bash scripts/neon-connect.sh",
    "neon:run-schema": "node scripts/run-missing-tables.js",
    "neon:migrate": "node --env-file=.env.neon scripts/run-missing-tables.js",
    "neon:migrate:cli": "bash scripts/neon-migrate-with-cli.sh",
    "test:order-totals": "node scripts/test-order-totals.js",
    "test:api-write-routes": "node scripts/test-api-write-routes.js",
    "test:product-db": "node scripts/smoke-product-db-write.mjs",
    "test:parcel-tracking": "node scripts/test-parcel-tracking.js"
  },
  "devDependencies": {
    "neonctl": "^2.22.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@vercel/blob": "^2.3.1",
    "apns2": "^12.2.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "multiparty": "^4.2.3",
    "pg": "^8.13.0",
    "stripe": "^20.4.1"
  }
}
